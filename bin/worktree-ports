#!/usr/bin/env bash
# Auto-allocate ports and derive per-worktree configuration.
# Source this file from other scripts: source "$PROJECT_ROOT/bin/worktree-ports"
#
# Exports:
#   BACKEND_PORT     — available port from 8000–8009
#   REDIS_DB_INDEX   — derived from port offset (e.g., port 8002 → index 2)
#   REDIS_URL        — redis://localhost:6379/$REDIS_DB_INDEX

set -euo pipefail

# Set PROJECT_ROOT if not already set (handles direct execution)
PROJECT_ROOT="${PROJECT_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"

source "$PROJECT_ROOT/bin/utils"

# Port range for worktree dev servers
PORT_RANGE_START=8000
PORT_RANGE_END=8009

# Find the first available port in range
find_available_port() {
    for port in $(seq $PORT_RANGE_START $PORT_RANGE_END); do
        if ! lsof -iTCP:"$port" -sTCP:LISTEN -P -n &>/dev/null; then
            echo "$port"
            return 0
        fi
    done
    echo ""
    return 1
}

# Main configuration function — sets all env vars
get_worktree_config() {
    # Allow override via environment
    if [ -n "${BACKEND_PORT:-}" ]; then
        print_info "Using pre-set BACKEND_PORT=$BACKEND_PORT"
    else
        BACKEND_PORT=$(find_available_port)
        if [ -z "$BACKEND_PORT" ]; then
            print_error "No available ports in range $PORT_RANGE_START–$PORT_RANGE_END"
            exit 1
        fi
    fi

    # Derive Redis DB index from port offset
    REDIS_DB_INDEX=$(( BACKEND_PORT - PORT_RANGE_START ))

    # Build Redis URL with DB index
    REDIS_URL="redis://localhost:6379/${REDIS_DB_INDEX}"

    # Also set LISTEN_PORT for the FastAPI server
    LISTEN_PORT="$BACKEND_PORT"

    export BACKEND_PORT
    export REDIS_DB_INDEX
    export REDIS_URL
    export LISTEN_PORT
}

# Write a .dev-server file documenting the active config
write_dev_info() {
    local dev_server_file="$PROJECT_ROOT/.dev-server"
    cat > "$dev_server_file" <<EOF
# Active dev server configuration
# Generated by bin/worktree-ports — do not edit
BACKEND_PORT=$BACKEND_PORT
REDIS_DB_INDEX=$REDIS_DB_INDEX
REDIS_URL=$REDIS_URL
BRANCH=$(git -C "$PROJECT_ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
STARTED_AT=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
EOF
}

# Display current configuration
show_worktree_config() {
    print_header "Worktree Dev Configuration"
    echo "  BACKEND_PORT:    $BACKEND_PORT"
    echo "  REDIS_DB_INDEX:  $REDIS_DB_INDEX"
    echo "  REDIS_URL:       $REDIS_URL"
    echo "  BRANCH:          $(git -C "$PROJECT_ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")"
}

# If run directly (not sourced), allocate and display
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    get_worktree_config
    show_worktree_config
fi
