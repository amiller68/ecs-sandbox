#!/bin/bash
# Start development servers in tmux
set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$PROJECT_ROOT/bin/utils"

# Allocate ports and derive per-worktree config
source "$PROJECT_ROOT/bin/worktree-ports"
get_worktree_config

# Derive tmux session name from branch
BRANCH_NAME=$(git -C "$PROJECT_ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "main")
SESSION_NAME="ecs-sandbox-$(echo "$BRANCH_NAME" | sed 's/[^a-zA-Z0-9._-]/-/g')"

# Parse arguments
KILL_SESSION=false
for arg in "$@"; do
    case $arg in
        --kill) KILL_SESSION=true ;;
    esac
done

# Kill existing session if requested
if [ "$KILL_SESSION" = true ]; then
    if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
        tmux kill-session -t "$SESSION_NAME"
        print_success "Killed tmux session: $SESSION_NAME"
    else
        print_warning "No active session: $SESSION_NAME"
    fi
    # Clean up .dev-server
    rm -f "$PROJECT_ROOT/.dev-server"
    exit 0
fi

# Check if tmux is available
if ! command -v tmux &>/dev/null; then
    print_error "tmux is not installed. Install it with: brew install tmux"
    exit 1
fi

# Kill existing session if it exists
if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
    print_warning "Killing existing session: $SESSION_NAME"
    tmux kill-session -t "$SESSION_NAME"
fi

# Write .dev-server file and show config
write_dev_info
show_worktree_config

# Ensure data directory exists
mkdir -p "$PROJECT_ROOT/data"

# Export env vars so tmux panes inherit them
export BACKEND_PORT REDIS_DB_INDEX REDIS_URL LISTEN_PORT

print_header "Starting ecs-sandbox development environment"

# Create new tmux session with the sandbox server
tmux new-session -d -s "$SESSION_NAME" -n "server" \
    "cd $PROJECT_ROOT/apps/ecs-sandbox && LISTEN_PORT=$LISTEN_PORT REDIS_URL=$REDIS_URL make dev"

# Add pane for worker
tmux split-window -t "$SESSION_NAME:server" -v \
    "cd $PROJECT_ROOT/apps/ecs-sandbox && REDIS_URL=$REDIS_URL make worker"

# Add pane for scheduler
tmux split-window -t "$SESSION_NAME:server" -v \
    "cd $PROJECT_ROOT/apps/ecs-sandbox && REDIS_URL=$REDIS_URL make scheduler"

# Add pane for agent image watcher
tmux split-window -t "$SESSION_NAME:server" -v \
    "cd $PROJECT_ROOT/apps/ecs-sandbox && ./bin/agent-watch.sh"

# Even out the panes
tmux select-layout -t "$SESSION_NAME:server" even-vertical

print_success "Development environment started in tmux session: $SESSION_NAME"
echo ""
echo "  Server:  http://localhost:$BACKEND_PORT"
echo "  Attach:  tmux attach -t $SESSION_NAME"
echo "  Kill:    make dev ARGS='--kill'"
echo ""
