#!/usr/bin/env bash
# Manage git worktrees for parallel development.
#
# Usage:
#   worktree create <name> [branch]  — create worktree in .worktrees/<name>
#   worktree list                    — list active worktrees
#   worktree remove <name>           — clean up a worktree
#   worktree cleanup                 — remove all worktrees

set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$PROJECT_ROOT/bin/utils"

WORKTREE_DIR="$PROJECT_ROOT/.worktrees"

cmd_create() {
    local name="${1:?Usage: worktree create <name> [branch]}"
    local branch="${2:-}"
    local worktree_path="$WORKTREE_DIR/$name"

    if [ -d "$worktree_path" ]; then
        print_error "Worktree '$name' already exists at $worktree_path"
        exit 1
    fi

    mkdir -p "$WORKTREE_DIR"

    if [ -n "$branch" ]; then
        # Create worktree tracking an existing branch or create a new one
        if git -C "$PROJECT_ROOT" rev-parse --verify "$branch" &>/dev/null; then
            git -C "$PROJECT_ROOT" worktree add "$worktree_path" "$branch"
        else
            git -C "$PROJECT_ROOT" worktree add -b "$branch" "$worktree_path"
        fi
    else
        # Create a new branch named after the worktree
        git -C "$PROJECT_ROOT" worktree add -b "$name" "$worktree_path"
    fi

    print_success "Created worktree '$name' at $worktree_path"
    echo "  cd $worktree_path && make dev"
}

cmd_list() {
    print_header "Active Worktrees"
    git -C "$PROJECT_ROOT" worktree list
}

cmd_remove() {
    local name="${1:?Usage: worktree remove <name>}"
    local worktree_path="$WORKTREE_DIR/$name"

    if [ ! -d "$worktree_path" ]; then
        print_error "Worktree '$name' not found at $worktree_path"
        exit 1
    fi

    # Clean up .dev-server if present
    rm -f "$worktree_path/.dev-server"

    git -C "$PROJECT_ROOT" worktree remove "$worktree_path" --force
    print_success "Removed worktree '$name'"
}

cmd_cleanup() {
    print_header "Cleaning up all worktrees"

    if [ ! -d "$WORKTREE_DIR" ]; then
        print_info "No worktrees directory found"
        return 0
    fi

    for wt in "$WORKTREE_DIR"/*/; do
        [ -d "$wt" ] || continue
        local name
        name=$(basename "$wt")
        rm -f "$wt/.dev-server"
        git -C "$PROJECT_ROOT" worktree remove "$wt" --force 2>/dev/null || true
        print_success "Removed worktree '$name'"
    done

    # Prune stale worktree references
    git -C "$PROJECT_ROOT" worktree prune
    rmdir "$WORKTREE_DIR" 2>/dev/null || true
    print_success "Cleanup complete"
}

cmd_help() {
    echo "Usage: $(basename "$0") <command> [args]"
    echo ""
    echo "Commands:"
    echo "  create <name> [branch]  Create a new worktree"
    echo "  list                    List active worktrees"
    echo "  remove <name>           Remove a worktree"
    echo "  cleanup                 Remove all worktrees"
}

CMD="${1:-help}"
shift || true
case "$CMD" in
    create|list|remove|cleanup|help) "cmd_$CMD" "$@" ;;
    *) print_error "Unknown command: $CMD"; cmd_help; exit 1 ;;
esac
