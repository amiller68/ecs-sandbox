#!/usr/bin/env bash
# Shared utility functions for bin scripts
# Source this file from other scripts: source "$PROJECT_ROOT/bin/utils"

# Require PROJECT_ROOT
if [ -z "$PROJECT_ROOT" ]; then
    echo "Error: PROJECT_ROOT must be set before sourcing utils"
    exit 1
fi

# Colors for output
export RED='\033[0;31m'
export GREEN='\033[0;32m'
export YELLOW='\033[1;33m'
export BLUE='\033[0;34m'
export CYAN='\033[0;36m'
export GRAY='\033[0;90m'
export NC='\033[0m' # No Color

# Error counter
export ERRORS=0

print_header() {
    echo -e "\n${YELLOW}=== $1 ===${NC}"
}

print_success() {
    echo -e "${GREEN}✓ $1${NC}"
}

print_error() {
    echo -e "${RED}✗ $1${NC}"
}

print_warning() {
    echo -e "${YELLOW}⚠ $1${NC}"
}

print_info() {
    echo -e "${BLUE}ℹ $1${NC}"
}

check_result() {
    if [ $? -eq 0 ]; then
        echo -e "${GREEN}✓ $1 passed${NC}"
    else
        echo -e "${RED}✗ $1 failed${NC}"
        ERRORS=$((ERRORS + 1))
    fi
}

print_summary() {
    local success_msg="$1"
    local failure_msg="${2:-check(s) failed}"

    print_header "Summary"
    if [ $ERRORS -eq 0 ]; then
        echo -e "${GREEN}${success_msg}${NC}"
        return 0
    else
        echo -e "${RED}${ERRORS} ${failure_msg}${NC}"
        return 1
    fi
}

# Check if an item is in a space-separated list (string match)
is_in_list() {
    local list="$1"
    local item="$2"
    echo "$list" | grep -q "$item"
}
