# ecs-sandbox environment variables
# Copy to .env for local development, or use 1Password vault for deployed environments.

# Auth — shared secret for API authentication
SANDBOX_SECRET=dev-secret-change-me

# Docker — sandbox container configuration
SANDBOX_IMAGE=ecs-sandbox-agent:latest
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_CPU_LIMIT=0.5
SANDBOX_NETWORK=none
SANDBOX_PIDS_LIMIT=128

# Session — TTL and capacity
DEFAULT_TTL_SECONDS=1800
MAX_CONTAINERS=50

# Storage — SQLite and workspace backend
DB_PATH=/data/ecs-sandbox.db
WORKSPACE_BACKEND=efs
EFS_WORKSPACE_ROOT=/data/workspaces
S3_WORKSPACE_BUCKET=ecs-sandbox-workspaces

# Cleanup job — runs as a scheduled ECS task
CLEANUP_STALE_THRESHOLD_MINUTES=60
CLEANUP_RETENTION_DAYS=7
CLEANUP_ARCHIVE_TO_S3=false
CLEANUP_S3_BUCKET=ecs-sandbox-archive

# Background jobs — Redis broker for taskiq
REDIS_URL=redis://localhost:6379

# Dev CLI — Anthropic API key for the test agent
ANTHROPIC_API_KEY=sk-ant-...

# AWS — only needed for ECR push / ECS operations (normally from vault)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
